from typing import Literal

from ._rotation import Rotation

def icosahedral[RotationT: Rotation](cls: type[RotationT]) -> RotationT: ...
def octahedral[RotationT: Rotation](cls: type[RotationT]) -> RotationT: ...
def tetrahedral[RotationT: Rotation](cls: type[RotationT]) -> RotationT: ...
def dicyclic[RotationT: Rotation](cls: type[RotationT], n: int, axis: int = 2) -> RotationT: ...
def cyclic[RotationT: Rotation](cls: type[RotationT], n: int, axis: int = 2) -> RotationT: ...
def create_group[RotationT: Rotation](
    cls: type[RotationT], group: Literal["I", "O", "T", "Dn", "Cn"], axis: Literal["x", "y", "z", "X", "Y", "Z"] = "Z"
) -> RotationT: ...
