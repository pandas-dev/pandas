from _typeshed import Incomplete
from types import EllipsisType, ModuleType
from typing import Protocol, overload, type_check_only

@type_check_only
class _HasArrayNamespace(Protocol):
    def __array_namespace__(self, /) -> Incomplete: ...

###
# for the sake of simplicity, we assume that the array types do no include shape-typing information,
# and have the same input/output dtype

def from_quat[ArrayT: _HasArrayNamespace](
    quat: ArrayT, normalize: bool = True, copy: bool = True, *, scalar_first: bool = False
) -> ArrayT: ...
def from_matrix[ArrayT: _HasArrayNamespace](matrix: ArrayT, assume_valid: bool = False) -> ArrayT: ...
def _from_matrix_orthogonal[ArrayT: _HasArrayNamespace](matrix: ArrayT) -> ArrayT: ...
def from_rotvec[ArrayT: _HasArrayNamespace](rotvec: ArrayT, degrees: bool = False) -> ArrayT: ...
def from_mrp[ArrayT: _HasArrayNamespace](mrp: ArrayT) -> ArrayT: ...
def from_euler[ArrayT: _HasArrayNamespace](seq: str, angles: ArrayT, degrees: bool = False) -> ArrayT: ...
def from_davenport[ArrayT: _HasArrayNamespace](
    axes: ArrayT, order: str, angles: ArrayT | float, degrees: bool = False
) -> ArrayT: ...
def as_quat[ArrayT: _HasArrayNamespace](quat: ArrayT, canonical: bool = False, *, scalar_first: bool = False) -> ArrayT: ...
def as_matrix[ArrayT: _HasArrayNamespace](quat: ArrayT) -> ArrayT: ...
def as_rotvec[ArrayT: _HasArrayNamespace](quat: ArrayT, degrees: bool = False) -> ArrayT: ...
def as_mrp[ArrayT: _HasArrayNamespace](quat: ArrayT) -> ArrayT: ...
def as_euler[ArrayT: _HasArrayNamespace](
    quat: ArrayT, seq: str, degrees: bool = False, *, suppress_warnings: bool = False
) -> ArrayT: ...
def as_davenport[ArrayT: _HasArrayNamespace](
    quat: ArrayT, axes: ArrayT, order: str, degrees: bool = False, *, suppress_warnings: bool = False
) -> ArrayT: ...
def inv[ArrayT: _HasArrayNamespace](quat: ArrayT) -> ArrayT: ...
def magnitude[ArrayT: _HasArrayNamespace](quat: ArrayT) -> ArrayT: ...
def approx_equal[ArrayT: _HasArrayNamespace](
    quat: ArrayT, other: ArrayT, atol: float | None = None, degrees: bool = False
) -> Incomplete: ...
def mean[ArrayT: _HasArrayNamespace](
    quat: ArrayT, weights: ArrayT | None = None, axis: int | tuple[int, ...] | None = None
) -> ArrayT: ...

#
@overload
def reduce[ArrayT: _HasArrayNamespace](quat: ArrayT, left: None = None, right: None = None) -> tuple[ArrayT, None, None]: ...
@overload
def reduce[ArrayT: _HasArrayNamespace](
    quat: ArrayT, left: ArrayT, right: ArrayT | None = None
) -> tuple[ArrayT, ArrayT, ArrayT]: ...
@overload
def reduce[ArrayT: _HasArrayNamespace](quat: ArrayT, left: ArrayT | None, right: ArrayT) -> tuple[ArrayT, ArrayT, ArrayT]: ...
@overload
def reduce[ArrayT: _HasArrayNamespace](
    quat: ArrayT, left: ArrayT | None = None, *, right: ArrayT
) -> tuple[ArrayT, ArrayT, ArrayT]: ...

#
def apply[ArrayT: _HasArrayNamespace](quat: ArrayT, points: ArrayT, inverse: bool = False) -> ArrayT: ...
def setitem[ArrayT: _HasArrayNamespace](quat: ArrayT, value: ArrayT, indexer: int | slice | EllipsisType | None) -> ArrayT: ...
def align_vectors[ArrayT: _HasArrayNamespace](
    a: ArrayT, b: ArrayT, weights: ArrayT | None = None, return_sensitivity: bool = False
) -> tuple[ArrayT, ArrayT, ArrayT]: ...
def _align_vectors[ArrayT: _HasArrayNamespace](a: ArrayT, b: ArrayT, weights: ArrayT) -> tuple[ArrayT, ArrayT, ArrayT]: ...
def _align_vectors_fixed[ArrayT: _HasArrayNamespace](a: ArrayT, b: ArrayT, weights: ArrayT) -> tuple[ArrayT, ArrayT, ArrayT]: ...
def pow[ArrayT: _HasArrayNamespace](quat: ArrayT, n: float | ArrayT) -> ArrayT: ...
def _normalize_quaternion[ArrayT: _HasArrayNamespace](quat: ArrayT) -> ArrayT: ...
def _quat_canonical[ArrayT: _HasArrayNamespace](quat: ArrayT) -> ArrayT: ...
def _elementary_basis_index(axis: str) -> int: ...
def _compute_davenport_from_quat[ArrayT: _HasArrayNamespace](
    quat: ArrayT, n1: ArrayT, n2: ArrayT, n3: ArrayT, extrinsic: bool, suppress_warnings: bool
) -> ArrayT: ...
def _elementary_quat_compose[ArrayT: _HasArrayNamespace](axes: list[int], angles: ArrayT, intrinsic: bool) -> ArrayT: ...
def _make_elementary_quat[ArrayT: _HasArrayNamespace](axis: int, angle: ArrayT, device: object, xp: ModuleType) -> ArrayT: ...
def _get_angles[ArrayT: _HasArrayNamespace](
    extrinsic: bool, symmetric: bool, sign: int, lamb: float, a: ArrayT, b: ArrayT, c: ArrayT, d: ArrayT, suppress_warnings: bool
) -> ArrayT: ...
def compose_quat[ArrayT: _HasArrayNamespace](p: ArrayT, q: ArrayT) -> ArrayT: ...
def _split_rotation[ArrayT: _HasArrayNamespace](q: ArrayT, xp: ModuleType) -> tuple[ArrayT, ArrayT]: ...
def _deg2rad[ArrayT: _HasArrayNamespace](angles: ArrayT) -> ArrayT: ...
def _rad2deg[ArrayT: _HasArrayNamespace](angles: ArrayT) -> ArrayT: ...
