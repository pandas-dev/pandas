from _typeshed import Incomplete
from typing import Protocol, type_check_only

@type_check_only
class _HasArrayNamespace(Protocol):
    def __array_namespace__(self, /) -> Incomplete: ...

###
# for the sake of simplicity, we assume that the array types do no include shape-typing information,
# and have the same input/output dtype

def from_matrix[ArrayT: _HasArrayNamespace](matrix: ArrayT, normalize: bool = True, copy: bool = True) -> ArrayT: ...
def from_rotation[ArrayT: _HasArrayNamespace](quat: ArrayT) -> ArrayT: ...
def from_translation[ArrayT: _HasArrayNamespace](translation: ArrayT) -> ArrayT: ...
def from_components[ArrayT: _HasArrayNamespace](translation: ArrayT, quat: ArrayT) -> ArrayT: ...
def from_exp_coords[ArrayT: _HasArrayNamespace](exp_coords: ArrayT) -> ArrayT: ...
def from_dual_quat[ArrayT: _HasArrayNamespace](dual_quat: ArrayT, *, scalar_first: bool = False) -> ArrayT: ...
def as_exp_coords[ArrayT: _HasArrayNamespace](matrix: ArrayT) -> ArrayT: ...
def as_dual_quat[ArrayT: _HasArrayNamespace](matrix: ArrayT, *, scalar_first: bool = False) -> ArrayT: ...
def compose_transforms[ArrayT: _HasArrayNamespace](tf_matrix: ArrayT, other_tf_matrix: ArrayT) -> ArrayT: ...
def inv[ArrayT: _HasArrayNamespace](matrix: ArrayT) -> ArrayT: ...
def apply[ArrayT: _HasArrayNamespace](matrix: ArrayT, vector: ArrayT, inverse: bool = False) -> ArrayT: ...
def pow[ArrayT: _HasArrayNamespace](matrix: ArrayT, n: float | ArrayT) -> ArrayT: ...
def mean[ArrayT: _HasArrayNamespace](
    matrix: ArrayT, weights: Incomplete | None = None, axis: int | tuple[int, ...] | None = None
) -> ArrayT: ...
def setitem[ArrayT: _HasArrayNamespace](matrix: ArrayT, indexer: Incomplete, value: ArrayT) -> ArrayT: ...
def normalize_dual_quaternion[ArrayT: _HasArrayNamespace](dual_quat: ArrayT) -> ArrayT: ...
def _create_transformation_matrix[ArrayT: _HasArrayNamespace](translations: ArrayT, rotation_matrices: ArrayT) -> ArrayT: ...
def _compute_se3_exp_translation_transform[ArrayT: _HasArrayNamespace](rot_vec: ArrayT) -> ArrayT: ...
def _compute_se3_log_translation_transform[ArrayT: _HasArrayNamespace](rot_vec: ArrayT) -> ArrayT: ...
def _create_skew_matrix[ArrayT: _HasArrayNamespace](vec: ArrayT) -> ArrayT: ...
def _normalize_dual_quaternion[ArrayT: _HasArrayNamespace](real_part: ArrayT, dual_part: ArrayT) -> tuple[ArrayT, ArrayT]: ...
