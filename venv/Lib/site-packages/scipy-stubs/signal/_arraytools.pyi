from typing import Literal, SupportsIndex, overload

import numpy as np
import optype.numpy as onp

def axis_slice[ScalarT: np.generic](
    a: onp.ArrayND[ScalarT],
    start: SupportsIndex | None = None,
    stop: SupportsIndex | None = None,
    step: SupportsIndex | None = None,
    axis: SupportsIndex = -1,
) -> onp.ArrayND[ScalarT]: ...
def axis_reverse[ScalarT: np.generic](a: onp.ArrayND[ScalarT], axis: SupportsIndex = -1) -> onp.ArrayND[ScalarT]: ...

#
def odd_ext[ScalarT: np.generic](x: onp.ArrayND[ScalarT], n: onp.ToInt, axis: SupportsIndex = -1) -> onp.ArrayND[ScalarT]: ...
def even_ext[ScalarT: np.generic](x: onp.ArrayND[ScalarT], n: onp.ToInt, axis: SupportsIndex = -1) -> onp.ArrayND[ScalarT]: ...
def const_ext[ScalarT: np.generic](x: onp.ArrayND[ScalarT], n: onp.ToInt, axis: SupportsIndex = -1) -> onp.ArrayND[ScalarT]: ...
def zero_ext[ScalarT: np.generic](x: onp.ArrayND[ScalarT], n: onp.ToInt, axis: SupportsIndex = -1) -> onp.ArrayND[ScalarT]: ...

#
@overload
def _validate_fs(fs: None, allow_none: Literal[True] = True) -> None: ...
@overload
def _validate_fs(fs: onp.ToFloat, allow_none: bool = True) -> float: ...
