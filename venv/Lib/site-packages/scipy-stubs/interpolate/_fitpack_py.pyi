@overload  # tck: 1-d
def insert(x: onp.ToFloat, tck: _ToTCK1D, m: int = 1, per: bool | Literal[0, 1] = 0) -> _TCK1D: ...
@overload  # tck: 2-d
def insert(x: onp.ToFloat, tck: _ToTCK2D, m: int = 1, per: bool | Literal[0, 1] = 0) -> _TCK2D: ...
@overload  # tck: ?-d
def insert(x: onp.ToFloat, tck: _ToTCK, m: int = 1, per: bool | Literal[0, 1] = 0) -> _TCK1D | _TCK2D: ...

