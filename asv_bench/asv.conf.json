{
    "version": 1,
    "project": "pandas",
    "project_url": "https://pandas.pydata.org/",
    "repo": "..",
    "branches": ["main"],
    "environment_type": "rattler",
    "show_commit_url": "https://github.com/pandas-dev/pandas/commit/",
    "matrix": {
        "pip+build": [],
        "Cython": [],
        "matplotlib": [],
        "sqlalchemy": [],
        "scipy": [],
        "numba": [],
        "numexpr": [],
        "pytables": [],
        "pyarrow": [],
        "openpyxl": [],
        "xlsxwriter": [],
        "odfpy": [],
        "jinja2": [],
        "meson": [],
        "meson-python": [],
        "python-build": []
    },
    "conda_channels": ["conda-forge"],
    "build_cache_size": 8,
    "regressions_first_commits": {
        ".*": "0409521665"
    },
    "build_command":
    ["python -m build -Cbuilddir=builddir --wheel --outdir {build_cache_dir} {build_dir}"]
}
